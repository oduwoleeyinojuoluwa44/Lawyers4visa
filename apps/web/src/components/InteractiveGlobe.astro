    const pointInPolygon = (latitude, longitude, polygon) => {
      let isInside = false;

      for (let index = 0, previous = polygon.length - 1; index < polygon.length; previous = index++) {
        const [currentLat, currentLon] = polygon[index];
        const [previousLat, previousLon] = polygon[previous];
        const intersects = ((currentLat > latitude) !== (previousLat > latitude))
          && (
            longitude
              < ((previousLon - currentLon) * (latitude - currentLat)) / ((previousLat - currentLat) || 0.00001)
                + currentLon
          );

        if (intersects) {
          isInside = !isInside;
        }
      }

      return isInside;
    };

    const densifyPolygon = (polygon, step = 2) => {
      const points = [];

      for (let index = 0; index < polygon.length; index += 1) {
        const current = polygon[index];
        const next = polygon[(index + 1) % polygon.length];
        const deltaLat = next[0] - current[0];
        const deltaLon = next[1] - current[1];
        const totalSteps = Math.max(2, Math.ceil(Math.max(Math.abs(deltaLat), Math.abs(deltaLon)) / step));

        for (let pointIndex = 0; pointIndex < totalSteps; pointIndex += 1) {
          const progress = pointIndex / totalSteps;

          points.push([
            current[0] + deltaLat * progress,
            current[1] + deltaLon * progress
          ]);
        }
      }

      return points;
    };

    const rotatePoint = (point, rotationY, rotationX) => {
      const cosY = Math.cos(rotationY);
      const sinY = Math.sin(rotationY);
      const cosX = Math.cos(rotationX);
      const sinX = Math.sin(rotationX);

      const rotatedY = {
        x: point.x * cosY - point.z * sinY,
        y: point.y,
        z: point.x * sinY + point.z * cosY
      };

      return {
        x: rotatedY.x,
        y: rotatedY.y * cosX - rotatedY.z * sinX,
        z: rotatedY.y * sinX + rotatedY.z * cosX
      };
    };

    const projectPoint = (point, radiusPx, centerX, centerY) => {
      const cameraDistance = 3.4;
      const perspective = cameraDistance / (cameraDistance - point.z);

      return {
        x: centerX + point.x * radiusPx * perspective,
        y: centerY + point.y * radiusPx * perspective,
        z: point.z,
        scale: perspective
      };
    };

    const buildGridSegments = ({
      longitudeStep = 20,
      latitudeStep = 6,
      ringLatitudeStep = 20,
      ringLongitudeStep = 6
    } = {}) => {
      const segments = [];

      for (let longitude = -180; longitude < 180; longitude += longitudeStep) {
        for (let latitude = -80; latitude < 80; latitude += latitudeStep) {
          segments.push([
            latLonToVector(latitude, longitude),
            latLonToVector(latitude + latitudeStep, longitude)
          ]);
        }
      }

      for (let latitude = -60; latitude <= 60; latitude += ringLatitudeStep) {
        for (let longitude = -180; longitude < 180; longitude += ringLongitudeStep) {
          segments.push([
            latLonToVector(latitude, longitude),
            latLonToVector(latitude, longitude + ringLongitudeStep)
          ]);
        }
      }

      return segments;
    };

    const isLandCoordinate = (latitude, longitude) =>
      worldPolygons.some((polygon) => pointInPolygon(latitude, longitude, polygon));

    const buildLandDots = ({
      dotStep = 2.4,
      reliefModulo = 21,
      reliefThreshold = 6,
      reliefOffset = 0.3
    } = {}) => {
      const landDots = [];
      const reliefDots = [];

      for (let latitude = -72; latitude <= 84; latitude += dotStep) {
        for (let longitude = -180; longitude <= 180; longitude += dotStep) {
          if (!isLandCoordinate(latitude, longitude)) {
            continue;
          }

          landDots.push(latLonToVector(latitude, longitude));

          const reliefSeed = Math.abs(
            ((latitude + 90) * 31 + (longitude + 180) * 17 + Math.round(latitude * longitude))
              % reliefModulo
          );

          if (reliefSeed < reliefThreshold) {
            reliefDots.push(
              latLonToVector(
                latitude + Math.sin((longitude + latitude) * DEG) * reliefOffset,
                longitude + Math.cos((longitude - latitude) * DEG) * reliefOffset
              )
            );
          }
        }
      }

      return { landDots, reliefDots };
    };

    const buildCoastSegments = ({ densifyStep = 2.8 } = {}) => {
      const segments = [];

      worldPolygons.forEach((polygon) => {
        const points = densifyPolygon(polygon, densifyStep);

        for (let index = 0; index < points.length; index += 1) {
          const current = points[index];
          const next = points[(index + 1) % points.length];

          segments.push([
            latLonToVector(current[0], current[1]),
            latLonToVector(next[0], next[1])
          ]);
        }
      });

      return segments;
    };

    const slerp = (from, to, amount) => {
      const start = normalize(from);
      const end = normalize(to);
      const angle = Math.acos(clamp(dot(start, end), -1, 1));

      if (angle < 0.001) {
        return start;
      }

      const sinAngle = Math.sin(angle);
      const startWeight = Math.sin((1 - amount) * angle) / sinAngle;
      const endWeight = Math.sin(amount * angle) / sinAngle;

      return normalize({
        x: start.x * startWeight + end.x * endWeight,
        y: start.y * startWeight + end.y * endWeight,
        z: start.z * startWeight + end.z * endWeight
      });
    };

    const buildArc = (fromLat, fromLon, toLat, toLon, steps = 32) => {
      const origin = latLonToVector(fromLat, fromLon);
      const target = latLonToVector(toLat, toLon);
      const points = [];

      for (let step = 0; step <= steps; step += 1) {
        const progress = step / steps;
        const point = slerp(origin, target, progress);
        const lift = 1 + 0.18 * Math.sin(progress * Math.PI);

        points.push({
          x: point.x * lift,
          y: point.y * lift,
          z: point.z * lift
        });
      }

      return points;
    };

    document.querySelectorAll("[data-lv-globe]").forEach((stage) => {
      if (stage.dataset.ready === "true") {
        return;
      }

      stage.dataset.ready = "true";

      const canvas = stage.querySelector("canvas");
      const context = canvas?.getContext("2d");

      if (!canvas || !context) {
        return;
      }

      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const coarsePointer = window.matchMedia("(pointer: coarse)").matches;
      const lowPowerDevice = coarsePointer
        || (navigator.hardwareConcurrency || 8) <= 4
        || ((navigator.deviceMemory || 8) <= 4);
      let width = 0;
      let height = 0;
      let rotationY = -0.48;
      let rotationX = -0.18;
      let velocityY = 0;
      let velocityX = 0;
      let dragging = false;
      let pointerX = 0;
      let pointerY = 0;
      let frameId = 0;
      let lastFrameTime = 0;
      let isStageVisible = true;
      let isPageVisible = document.visibilityState !== "hidden";
      let detailKey = "";
      let gridSegments = [];
      let landDots = [];
      let reliefDots = [];
      let coastSegments = [];
      let routeArcs = [];
      const ukMarker = latLonToVector(54.5, -2.5);

      const getDetailProfile = (currentWidth) => {
        if (reducedMotion || lowPowerDevice || currentWidth < 360) {
          return {
            key: "low",
            maxDpr: 1,
            idleFps: 20,
            grid: { longitudeStep: 30, latitudeStep: 10, ringLatitudeStep: 30, ringLongitudeStep: 10 },
            land: { dotStep: 4.2, reliefModulo: 25, reliefThreshold: 3, reliefOffset: 0.24 },
            coast: { densifyStep: 4.8 },
            arcSteps: 20
          };
        }

        if (coarsePointer || currentWidth < 560) {
          return {
            key: "medium",
            maxDpr: 1.2,
            idleFps: 24,
            grid: { longitudeStep: 24, latitudeStep: 8, ringLatitudeStep: 24, ringLongitudeStep: 8 },
            land: { dotStep: 3.2, reliefModulo: 23, reliefThreshold: 4, reliefOffset: 0.28 },
            coast: { densifyStep: 3.6 },
            arcSteps: 24
          };
        }

        return {
          key: "high",
          maxDpr: 1.35,
          idleFps: 28,
          grid: { longitudeStep: 20, latitudeStep: 7, ringLatitudeStep: 20, ringLongitudeStep: 7 },
          land: { dotStep: 2.8, reliefModulo: 21, reliefThreshold: 5, reliefOffset: 0.3 },
          coast: { densifyStep: 3 },
          arcSteps: 28
        };
      };

      const rebuildGeometry = (profile) => {
        gridSegments = buildGridSegments(profile.grid);
        ({ landDots, reliefDots } = buildLandDots(profile.land));
        coastSegments = buildCoastSegments(profile.coast);
        routeArcs = [
          buildArc(6.5244, 3.3792, 54.5, -2.5, profile.arcSteps),
          buildArc(28.6139, 77.209, 54.5, -2.5, profile.arcSteps),
          buildArc(40.7128, -74.006, 54.5, -2.5, profile.arcSteps)
        ];
      };

      const renderFrame = () => {
        if (!width || !height) {
          return;
        }

        context.clearRect(0, 0, width, height);

        const centerX = width / 2;
        const centerY = height / 2;
        const radius = Math.min(width, height) * 0.36;

        if (!dragging) {
          rotationY += velocityY;
          rotationX = clamp(rotationX + velocityX, -0.7, 0.55);

          if (!reducedMotion) {
            rotationY += 0.0022;
          }

          velocityY *= 0.92;
          velocityX *= 0.84;
        }

        drawOrbit(centerX, centerY, radius);
        drawSphere(centerX, centerY, radius);
        drawGrid(centerX, centerY, radius);
        drawArcs(centerX, centerY, radius);
        drawMarker(centerX, centerY, radius);
      };

      const shouldAnimate = () => (
        isStageVisible
        && isPageVisible
        && (!reducedMotion || dragging || Math.abs(velocityY) > 0.00005 || Math.abs(velocityX) > 0.00005)
      );

      const stopLoop = () => {
        if (frameId) {
          window.cancelAnimationFrame(frameId);
          frameId = 0;
        }
      };

      const tick = (timestamp = 0) => {
        frameId = 0;

        if (!shouldAnimate()) {
          renderFrame();
          return;
        }

        const profile = getDetailProfile(width);
        const frameInterval = dragging ? 1000 / 60 : 1000 / profile.idleFps;

        if (timestamp - lastFrameTime >= frameInterval - 2) {
          lastFrameTime = timestamp;
          renderFrame();
        }

        if (shouldAnimate()) {
          frameId = window.requestAnimationFrame(tick);
        }
      };

      const startLoop = () => {
        if (!frameId && shouldAnimate()) {
          frameId = window.requestAnimationFrame(tick);
        }
      };

      const resize = () => {
        const bounds = stage.getBoundingClientRect();
        const profile = getDetailProfile(bounds.width);
        const ratio = Math.min(window.devicePixelRatio || 1, profile.maxDpr);

        width = bounds.width;
        height = bounds.height;
        canvas.width = Math.max(1, Math.round(bounds.width * ratio));
        canvas.height = Math.max(1, Math.round(bounds.height * ratio));
        context.setTransform(ratio, 0, 0, ratio, 0, 0);

        if (detailKey !== profile.key) {
          detailKey = profile.key;
          rebuildGeometry(profile);
        }

        renderFrame();
        startLoop();
      };

      const drawSphere = (centerX, centerY, radius) => {
        const fill = context.createRadialGradient(
          centerX - radius * 0.35,
          centerY - radius * 0.42,
          radius * 0.12,
          centerX,
          centerY,
          radius * 1.08
        );

        fill.addColorStop(0, "rgba(255, 248, 241, 0.98)");
        fill.addColorStop(0.28, "rgba(210, 164, 126, 0.96)");
        fill.addColorStop(0.58, "rgba(127, 77, 38, 0.98)");
        fill.addColorStop(1, "rgba(57, 25, 0, 1)");

        context.beginPath();
        context.arc(centerX, centerY, radius, 0, TAU);
        context.fillStyle = fill;
        context.fill();

        const rim = context.createLinearGradient(
          centerX - radius,
          centerY - radius,
          centerX + radius,
          centerY + radius
        );

        rim.addColorStop(0, "rgba(255, 241, 230, 0.45)");
        rim.addColorStop(1, "rgba(95, 41, 0, 0.18)");

        context.beginPath();
        context.arc(centerX, centerY, radius, 0, TAU);
        context.lineWidth = Math.max(1, radius * 0.012);
        context.strokeStyle = rim;
        context.stroke();
      };

      const drawGrid = (centerX, centerY, radius) => {
        context.save();
        context.beginPath();
        context.arc(centerX, centerY, radius, 0, TAU);
        context.clip();

        gridSegments.forEach(([start, end]) => {
          const projectedStart = projectPoint(
            rotatePoint(start, rotationY, rotationX),
            radius,
            centerX,
            centerY
          );
          const projectedEnd = projectPoint(
            rotatePoint(end, rotationY, rotationX),
            radius,
            centerX,
            centerY
          );

          const averageDepth = (projectedStart.z + projectedEnd.z) / 2;
          const alpha = averageDepth > 0
            ? 0.16 + averageDepth * 0.18
            : 0.03 + (averageDepth + 1) * 0.04;

          context.beginPath();
          context.moveTo(projectedStart.x, projectedStart.y);
          context.lineTo(projectedEnd.x, projectedEnd.y);
          context.lineWidth = averageDepth > 0 ? 1.05 : 0.7;
          context.strokeStyle = averageDepth > 0
            ? `rgba(255, 235, 216, ${alpha})`
            : `rgba(120, 73, 42, ${alpha})`;
          context.stroke();
        });

        landDots.forEach((dotPoint) => {
          const projectedPoint = projectPoint(
            rotatePoint(dotPoint, rotationY, rotationX),
            radius,
            centerX,
            centerY
          );

          const alpha = projectedPoint.z > 0
            ? 0.22 + projectedPoint.z * 0.26
            : 0.04 + (projectedPoint.z + 1) * 0.03;

          context.beginPath();
          context.arc(
            projectedPoint.x,
            projectedPoint.y,
            Math.max(0.85, projectedPoint.scale * 1.15),
            0,
            TAU
          );
          context.fillStyle = projectedPoint.z > 0
            ? `rgba(255, 226, 198, ${alpha})`
            : `rgba(171, 112, 66, ${alpha})`;
          context.fill();
        });

        reliefDots.forEach((dotPoint) => {
          const projectedPoint = projectPoint(
            rotatePoint(dotPoint, rotationY, rotationX),
            radius,
            centerX,
            centerY
          );

          if (projectedPoint.z < -0.18) {
            return;
          }

          const alpha = projectedPoint.z > 0
            ? 0.08 + projectedPoint.z * 0.16
            : 0.03 + (projectedPoint.z + 1) * 0.03;

          context.beginPath();
          context.arc(
            projectedPoint.x,
            projectedPoint.y,
            Math.max(0.4, projectedPoint.scale * 0.65),
            0,
            TAU
          );
          context.fillStyle = projectedPoint.z > 0
            ? `rgba(88, 45, 17, ${alpha})`
            : `rgba(120, 69, 34, ${alpha})`;
          context.fill();
        });

        coastSegments.forEach(([start, end]) => {
          const projectedStart = projectPoint(
            rotatePoint(start, rotationY, rotationX),
            radius,
            centerX,
            centerY
          );
          const projectedEnd = projectPoint(
            rotatePoint(end, rotationY, rotationX),
            radius,
            centerX,
            centerY
          );

          const averageDepth = (projectedStart.z + projectedEnd.z) / 2;

          if (averageDepth < -0.12) {
            return;
          }

          context.beginPath();
          context.moveTo(projectedStart.x, projectedStart.y);
          context.lineTo(projectedEnd.x, projectedEnd.y);
          context.lineWidth = averageDepth > 0 ? 1.2 : 0.8;
          context.strokeStyle = averageDepth > 0
            ? `rgba(255, 241, 229, ${0.24 + averageDepth * 0.22})`
            : `rgba(156, 97, 54, ${0.08 + (averageDepth + 1) * 0.05})`;
          context.stroke();
        });

        context.restore();
      };

      const drawArcs = (centerX, centerY, radius) => {
        routeArcs.forEach((arcPoints, index) => {
          context.beginPath();

          arcPoints.forEach((point, pointIndex) => {
            const projectedPoint = projectPoint(
              rotatePoint(point, rotationY, rotationX),
              radius,
              centerX,
              centerY
            );

            if (pointIndex === 0) {
              context.moveTo(projectedPoint.x, projectedPoint.y);
              return;
            }

            context.lineTo(projectedPoint.x, projectedPoint.y);
          });

          const opacity = 0.22 + index * 0.08;
          context.lineWidth = 1.25;
          context.strokeStyle = `rgba(255, 182, 111, ${opacity})`;
          context.shadowColor = "rgba(255, 183, 104, 0.18)";
          context.shadowBlur = 12;
          context.stroke();
          context.shadowBlur = 0;
        });
      };

      const drawMarker = (centerX, centerY, radius) => {
        const projectedMarker = projectPoint(
          rotatePoint(ukMarker, rotationY, rotationX),
          radius,
          centerX,
          centerY
        );

        if (projectedMarker.z < -0.05) {
          return;
        }

        context.beginPath();
        context.arc(projectedMarker.x, projectedMarker.y, 5.5, 0, TAU);
        context.fillStyle = "rgba(255, 239, 225, 0.98)";
        context.shadowColor = "rgba(255, 190, 122, 0.55)";
        context.shadowBlur = 18;
        context.fill();
        context.shadowBlur = 0;

        context.beginPath();
        context.arc(projectedMarker.x, projectedMarker.y, 11, 0, TAU);
        context.strokeStyle = "rgba(255, 205, 150, 0.4)";
        context.lineWidth = 1.2;
        context.stroke();
      };

      const drawOrbit = (centerX, centerY, radius) => {
        context.beginPath();
        context.ellipse(
          centerX,
          centerY + radius * 0.1,
          radius * 1.12,
          radius * 0.42,
          -0.22,
          0,
          TAU
        );
        context.strokeStyle = "rgba(181, 117, 63, 0.18)";
        context.lineWidth = 1.2;
        context.stroke();
      };

      const onPointerDown = (event) => {
        dragging = true;
        pointerX = event.clientX;
        pointerY = event.clientY;
        velocityY = 0;
        velocityX = 0;
        stage.classList.add("is-dragging");
        stage.setPointerCapture?.(event.pointerId);
        startLoop();
      };

      const onPointerMove = (event) => {
        if (!dragging) {
          return;
        }

        const deltaX = event.clientX - pointerX;
        const deltaY = event.clientY - pointerY;

        pointerX = event.clientX;
        pointerY = event.clientY;
        rotationY += deltaX * 0.005;
        rotationX = clamp(rotationX + deltaY * 0.004, -0.7, 0.55);
        velocityY = deltaX * 0.00055;
        velocityX = deltaY * 0.0004;
        renderFrame();
        startLoop();
      };

      const releasePointer = (event) => {
        if (!dragging) {
          return;
        }

        dragging = false;
        stage.classList.remove("is-dragging");

        try {
          stage.releasePointerCapture?.(event.pointerId);
        } catch {}

        startLoop();
      };

      resize();

      const resizeObserver = new ResizeObserver(resize);
      resizeObserver.observe(stage);
      const visibilityObserver = new IntersectionObserver(
        ([entry]) => {
          isStageVisible = Boolean(entry?.isIntersecting);

          if (isStageVisible) {
            renderFrame();
            startLoop();
            return;
          }

          stopLoop();
        },
        {
          threshold: 0.12
        }
      );
      visibilityObserver.observe(stage);

      const onVisibilityChange = () => {
        isPageVisible = document.visibilityState !== "hidden";

        if (isPageVisible) {
          renderFrame();
          startLoop();
          return;
        }

        stopLoop();
      };

      stage.addEventListener("pointerdown", onPointerDown);
      stage.addEventListener("pointermove", onPointerMove);
      stage.addEventListener("pointerup", releasePointer);
      stage.addEventListener("pointerleave", releasePointer);
      stage.addEventListener("pointercancel", releasePointer);
      document.addEventListener("visibilitychange", onVisibilityChange);

      window.addEventListener(
        "pagehide",
        () => {
          stopLoop();
          resizeObserver.disconnect();
          visibilityObserver.disconnect();
          document.removeEventListener("visibilitychange", onVisibilityChange);
        },
        { once: true }
      );
    });
  })();
</script>

