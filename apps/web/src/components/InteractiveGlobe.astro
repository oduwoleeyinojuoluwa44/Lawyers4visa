  .lv-stats__globe-stage {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    isolation: isolate;
  }

  .lv-stats__globe-stage::before {
    content: "";
    position: absolute;
    inset: 14% 18%;
    background: radial-gradient(circle, rgba(255, 229, 203, 0.32) 0%, rgba(196, 129, 72, 0.18) 42%, rgba(57, 25, 0, 0) 72%);
    filter: blur(34px);
    z-index: 0;
  }

  .lv-stats__globe-stage::after {
    content: "";
    position: absolute;
    inset: 4%;
    border: 1px solid rgba(148, 88, 45, 0.12);
    border-radius: 50%;
    z-index: 0;
  }

  .lv-stats__globe-canvas {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
    touch-action: none;
    filter: drop-shadow(0 36px 48px rgba(57, 25, 0, 0.16));
  }

  .lv-stats__globe-stage.is-dragging .lv-stats__globe-canvas {
    cursor: grabbing;
  }

  .lv-stats__globe-sheen {
    position: absolute;
    inset: 11% 18% 28% 20%;
    z-index: 2;
    border-radius: 50%;
    background:
      radial-gradient(circle at 28% 24%, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0) 36%),
      radial-gradient(circle at 70% 78%, rgba(255, 199, 147, 0.12), rgba(255, 199, 147, 0) 42%);
    pointer-events: none;
    mix-blend-mode: screen;
  }
</style>
