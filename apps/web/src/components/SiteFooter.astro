---
import { footerOffices } from "@lawyers4visa/content";

const socialLinks = [
  {
    label: "X",
    href: "#",
    icon: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.53 3h3.21l-7.01 8.01L22 21h-6.39l-5-6.54L4.9 21H1.68l7.5-8.58L1.33 3h6.55l4.52 5.96L17.53 3Zm-1.12 16.08h1.78L6.91 4.82H5.01L16.41 19.08Z" fill="currentColor"/></svg>`
  },
  {
    label: "Instagram",
    href: "#",
    icon: `<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5.25" y="5.25" width="13.5" height="13.5" rx="4" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="3.25" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="16.6" cy="7.4" r="0.8" fill="currentColor"/></svg>`
  },
  {
    label: "Facebook",
    href: "#",
    icon: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 8h2V5h-2.4C11.2 5 10 6.5 10 8.9V11H8v3h2v5h3v-5h2.6l.4-3H13V9.4c0-.8.3-1.4 1-1.4Z" fill="currentColor"/></svg>`
  },
  {
    label: "LinkedIn",
    href: "#",
    icon: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.2 8.6a1.4 1.4 0 1 1 0-2.8 1.4 1.4 0 0 1 0 2.8Zm-1.2 1.6h2.4V18H6V10.2Zm3.8 0h2.3v1.1h.03c.32-.6 1.1-1.23 2.27-1.23 2.42 0 2.87 1.6 2.87 3.68V18h-2.4v-3.6c0-.86-.02-1.97-1.2-1.97-1.2 0-1.39.94-1.39 1.91V18h-2.48V10.2Z" fill="currentColor"/></svg>`
  }
];
---

<footer class="lv-footer">
  <div class="lv-shell lv-footer__shell">
    <div class="lv-footer__primary">
      <div class="lv-footer__top">
        <p>&copy; 2026 Immigration Law Specialists. All rights reserved.</p>
        <p>Authorised and regulated by the relevant UK legal regulatory bodies.</p>
      </div>

      <div class="lv-footer__socials" aria-label="Social links">
        {
          socialLinks.map((item) => (
            <a href={item.href} aria-label={item.label}>
              <span set:html={item.icon} />
            </a>
          ))
        }
      </div>
    </div>

    <div class="lv-footer__offices">
      {
        footerOffices.map((office) => (
          <article>
            <h3>{office.title}</h3>
            <p>{office.detail}</p>
          </article>
        ))
      }
    </div>
  </div>
</footer>
