---
import {
  getImmigrationInsightAdjacentArticles,
  getImmigrationInsightRelatedArticles,
  immigrationInsightArticles,
  siteMetadata,
  type ImmigrationInsightArticle
} from "@lawyers4visa/content";

import SiteCtaBand from "../../components/SiteCtaBand.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";

export const prerender = true;

export const getStaticPaths = () =>
  immigrationInsightArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));

type Props = {
  article: ImmigrationInsightArticle;
};

const { article } = Astro.props as Props;
const relatedArticles = getImmigrationInsightRelatedArticles(article.slug);
const adjacentArticles = getImmigrationInsightAdjacentArticles(article.slug);
const articleCharacterCount =
  article.excerpt.length +
  article.sections.reduce(
    (total, section) =>
      total +
      section.blocks.reduce(
        (sectionTotal, block) =>
          sectionTotal +
          (block.type === "paragraph" ? block.text.length : block.items.join(" ").length),
        0
      ),
    0
  );
const isCompactArticleLayout = articleCharacterCount < 3400;

const shareIcons = {
  x: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.53 3h3.21l-7.01 8.01L22 21h-6.39l-5-6.54L4.9 21H1.68l7.5-8.58L1.33 3h6.55l4.52 5.96L17.53 3Zm-1.12 16.08h1.78L6.91 4.82H5.01L16.41 19.08Z" fill="currentColor"/></svg>`,
  instagram: `<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5.25" y="5.25" width="13.5" height="13.5" rx="4" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="3.25" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="16.6" cy="7.4" r="0.8" fill="currentColor"/></svg>`,
  facebook: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 8h2V5h-2.4C11.2 5 10 6.5 10 8.9V11H8v3h2v5h3v-5h2.6l.4-3H13V9.4c0-.8.3-1.4 1-1.4Z" fill="currentColor"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.2 8.6a1.4 1.4 0 1 1 0-2.8 1.4 1.4 0 0 1 0 2.8Zm-1.2 1.6h2.4V18H6V10.2Zm3.8 0h2.3v1.1h.03c.32-.6 1.1-1.23 2.27-1.23 2.42 0 2.87 1.6 2.87 3.68V18h-2.4v-3.6c0-.86-.02-1.97-1.2-1.97-1.2 0-1.39.94-1.39 1.91V18h-2.48V10.2Z" fill="currentColor"/></svg>`,
  copy: `<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="9" y="9" width="10" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M6.5 15V7.5A1.5 1.5 0 0 1 8 6h7.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`
};
---

<SiteLayout
  title={`${article.title} | ${siteMetadata.title}`}
  description={article.excerpt}
  bodyClass="immigration-insight-article-page"
  currentPath="/immigration-insights/"
>
  <main class="lv-main lv-insight-article-main">
    <section class="lv-insight-article-hero">
      <div class="lv-shell lv-insight-article-hero__shell">
        <div class="lv-insight-article-hero__meta">
          <span>{article.publishedLabel}</span>
          <span>{article.category}</span>
        </div>
        <h1>{article.title}</h1>
        <p class="lv-insight-article-hero__excerpt">{article.excerpt}</p>

        <div class="lv-insight-article-hero__media">
          <img src={article.heroImage} alt="" loading="eager" decoding="async" />
        </div>
      </div>
    </section>

    <section class="lv-insight-article-body">
      <div
        class:list={[
          "lv-shell lv-insight-article-body__shell",
          { "is-compact": isCompactArticleLayout }
        ]}
      >
        <article class="lv-insight-article-copy">
          {
            article.sections.map((section) => (
              <section class="lv-insight-section">
                <h2>{section.title}</h2>
                {
                  section.blocks.map((block) =>
                    block.type === "paragraph" ? (
                      <p>{block.text}</p>
                    ) : (
                      <ul>
                        {block.items.map((item) => <li>{item}</li>)}
                      </ul>
                    )
                  )
                }
              </section>
            ))
          }
        </article>

        <aside class="lv-insight-article-sidebar" data-share-panel>
          <div class="lv-insight-share">
            <div class="lv-insight-share__group">
              <p>Share to</p>
              <div class="lv-insight-share__links">
                <a href="#" aria-label="Share to X" data-share-link="x">
                  <span set:html={shareIcons.x} />
                </a>
                <a href="#" aria-label="Share to Instagram" data-share-link="instagram">
                  <span set:html={shareIcons.instagram} />
                </a>
                <a href="#" aria-label="Share to Facebook" data-share-link="facebook">
                  <span set:html={shareIcons.facebook} />
                </a>
                <a href="#" aria-label="Share to LinkedIn" data-share-link="linkedin">
                  <span set:html={shareIcons.linkedin} />
                </a>
              </div>
            </div>

            <div class="lv-insight-share__copy">
              <p>Copy link</p>
              <button type="button" aria-label="Copy article link" data-copy-link-button>
                <span set:html={shareIcons.copy} />
              </button>
            </div>
            <p class="lv-insight-share__status" data-copy-link-status aria-live="polite"></p>
          </div>

          <div class="lv-insight-related">
            <h2>Related Insights</h2>
            <div class="lv-insight-related__list">
              {
                relatedArticles.map((relatedArticle) => (
                  <article class="lv-insight-related__item">
                    <h3>
                      <a href={`/immigration-insights/${relatedArticle.slug}/`}>{relatedArticle.title}</a>
                    </h3>
                    <div class="lv-insight-related__meta">
                      <span>{relatedArticle.publishedLabel}</span>
                      <span>{relatedArticle.category}</span>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="lv-insight-adjacent" aria-label="Previous and next articles">
      <div class="lv-shell lv-insight-adjacent__shell">
        {
          adjacentArticles.previous ? (
            <a href={`/immigration-insights/${adjacentArticles.previous.slug}/`}>
              Previous
            </a>
          ) : (
            <span class="is-disabled">Previous</span>
          )
        }

        {
          adjacentArticles.next ? (
            <a href={`/immigration-insights/${adjacentArticles.next.slug}/`}>Next</a>
          ) : (
            <span class="is-disabled">Next</span>
          )
        }
      </div>
    </section>

    <SiteCtaBand
      title="Discuss Your UK Immigration Matter with a Specialist"
      description="Whether you require advice on a visa application, sponsor licence compliance, refusal response, or tribunal representation, we provide UK-based legal expertise grounded in immigration law and Home Office practice."
      href="/book-consultation/"
    />
  </main>

  <script is:inline>
    const sharePanel = document.querySelector("[data-share-panel]");

    if (sharePanel) {
      const currentUrl = window.location.href;
      const currentTitle = document.title;

      const shareUrls = {
        x: `https://x.com/intent/tweet?url=${encodeURIComponent(currentUrl)}&text=${encodeURIComponent(currentTitle)}`,
        instagram: currentUrl,
        facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(currentUrl)}`,
        linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(currentUrl)}`
      };

      sharePanel.querySelectorAll("[data-share-link]").forEach((link) => {
        const key = link.dataset.shareLink;

        if (!key || !shareUrls[key]) {
          return;
        }

        link.setAttribute("href", shareUrls[key]);

        if (key !== "instagram") {
          link.setAttribute("target", "_blank");
          link.setAttribute("rel", "noreferrer");
        }
      });

      const copyButton = sharePanel.querySelector("[data-copy-link-button]");
      const copyStatus = sharePanel.querySelector("[data-copy-link-status]");

      if (copyButton && copyStatus) {
        copyButton.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(currentUrl);
            copyStatus.textContent = "Link copied.";
          } catch {
            copyStatus.textContent = "Unable to copy link.";
          }
        });
      }
    }
  </script>
</SiteLayout>
