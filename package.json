{
  "name": "lawyersForvisas",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo -F @lawyersForvisas/web dev",
    "dev:studio": "turbo -F @lawyersForvisas/studio dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "postinstall": "node scripts/patch-astro-internal-helpers.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
